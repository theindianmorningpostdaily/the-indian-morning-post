# ---- The Indian Morning Post pipeline secrets ----
# Copy to .env for local runs. In CI these come from GitHub Actions secrets.

# Supabase (Project Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # NEVER expose to the frontend

# Google Gemini (free tier: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=YOUR_GEMINI_KEY
GEMINI_MODEL=gemini-2.5-flash                      # free tier, good quality

# Pipeline tuning (optional — defaults shown)
MAX_ARTICLES=5                # top stories to publish per daily run
MIN_SOURCES=2                 # required trusted sources to verify a story
LOOKBACK_HOURS=24             # how far back to consider news
DRY_RUN=false                # true = generate but do NOT write to DB

# Optional: trigger a Cloudflare Pages rebuild after publishing
CF_PAGES_DEPLOY_HOOK=
